def longestcommonprefix(str1):
    if not str1:
        return ""
    
    prefix = str1[0]
    
    for i in range(1, len(str1)):
        while not str1[i].startswith(prefix):
            prefix = prefix[:-1]
            if not prefix:
                return ""
    
    return prefix

# Get input from user
n = int(input("Enter number of strings: "))
str1 = []

for i in range(n):
    s = input(f"Enter string {i+1}: ")
    str1.append(s)

print(longestcommonprefix(str1))
