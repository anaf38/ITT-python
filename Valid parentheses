class Solution(object):
    def isValid(self, s):
        st = []
        for c in s:
            if c in "({[":
                st.append(c)
            elif c in ")}]":
                if not st: return False
                top = st.pop()
                if (c == ')' and top != '(') or \
                   (c == '}' and top != '{') or \
                   (c == ']' and top != '['):
                    return False
        return not st

if __name__ == '__main__':
    s = "[()()]{}"
    sol = Solution() # This will work now
    print("true" if sol.isValid(s) else "false")
